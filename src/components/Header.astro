---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

interface Props {
  forceScrolled?: boolean;
}

const { forceScrolled = false } = Astro.props;
---

<header class={forceScrolled ? 'scrolled' : ''}>
  <nav>
    <a class="nav-logo" href="/">{SITE_TITLE}</a>
    <div class="nav-links">
      <a class="linkedin-link" href="https://www.linkedin.com/in/dustinmartinka/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<script define:vars={{ forceScrolled }}>
  if (!forceScrolled) {
    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    }, { passive: true });
  }
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  header.scrolled {
    background: #201e1b;
    box-shadow: 0 1px 0 rgba(0,0,0,0.3);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 56px;
  }

  .nav-logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #f2ede8;
    text-decoration: none;
    opacity: 0.9;
    transition: color 0.3s ease;
  }

  header.scrolled .nav-logo {
    color: #f2ede8;
    opacity: 1;
  }

  .nav-links {
    display: flex;
    gap: 36px;
  }

  .nav-links :global(a) {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(242, 237, 232, 0.7);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .nav-links :global(a:hover),
  .nav-links :global(a.active) {
    color: #f2ede8;
  }

  header.scrolled .nav-links :global(a) {
    color: rgba(242, 237, 232, 0.7);
  }

  header.scrolled .nav-links :global(a:hover),
  header.scrolled .nav-links :global(a.active) {
    color: #f2ede8;
  }

  .linkedin-link {
    display: flex;
    align-items: center;
    color: rgba(242, 237, 232, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .linkedin-link:hover {
    color: #f2ede8;
  }

  @media (max-width: 800px) {
    nav {
      padding: 24px 32px;
    }
  }
</style>
