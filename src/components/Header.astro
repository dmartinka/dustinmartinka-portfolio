---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a class="nav-logo" href="/">{SITE_TITLE}</a>
    <div class="nav-links">
      <HeaderLink href="/work">Work</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }, { passive: true });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  header.scrolled {
    background: #201e1b;
    box-shadow: 0 1px 0 rgba(0,0,0,0.3);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 56px;
  }

  .nav-logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #f2ede8;
    text-decoration: none;
    opacity: 0.9;
    transition: color 0.3s ease;
  }

  header.scrolled .nav-logo {
    color: #f2ede8;
    opacity: 1;
  }

  .nav-links {
    display: flex;
    gap: 36px;
  }

  .nav-links :global(a) {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(242, 237, 232, 0.7);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .nav-links :global(a:hover),
  .nav-links :global(a.active) {
    color: #f2ede8;
  }

  header.scrolled .nav-links :global(a) {
    color: rgba(242, 237, 232, 0.7);
  }

  header.scrolled .nav-links :global(a:hover),
  header.scrolled .nav-links :global(a.active) {
    color: #f2ede8;
  }

  @media (max-width: 800px) {
    nav {
      padding: 24px 32px;
    }
  }
</style>
